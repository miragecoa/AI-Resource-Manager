{
  "name": "ai-cubby",
  "version": "0.2.65",
  "description": "AI小抽屉 - 本地资源自动入库与AI标签",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^3.6.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.4.2",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.11"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "pinia": "^2.1.7",
    "pinyin-pro": "^3.28.0",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.3.0"
  },
  "author": "miragecoa",
  "build": {
    "appId": "com.airesourcemanager.app",
    "productName": "AI-Cubby",
    "icon": "resources/icon.ico",
    "artifactName": "AI-Cubby-${version}-portable-${os}-${arch}.${ext}",
    "files": [
      "out/**/*",
      "resources/icon.*",
      "package.json",
      "!profiles/**",
      "!.update-temp/**",
      "!src/**",
      "!backend/**",
      "!frontend/**",
      "!*.ts"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*.node"
    ],
    "win": {
      "target": [
        "zip"
      ],
      "sign": "./build/empty-sign.js"
    },
    "forceCodeSigning": false
  }
}
